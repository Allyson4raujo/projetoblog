<nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
  <a class="navbar-brand" href="#">Meu Site</a>
  <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav">
    <span class="navbar-toggler-icon"></span>
  </button>
  <div class="collapse navbar-collapse" id="navbarNav">
    <ul class="navbar-nav">
      <li class="nav-item active">
        <a class="nav-link" href="#">Início</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="#">Sobre</a>
      </li>
    </ul>
  </div>
</nav>

<div class="p-5 mb-4 bg-light rounded-3 mt-5">
  <div class="container-fluid py-5">
    <h1 class="display-5 fw-bold">Bem-vindo ao Blog do Node !</h1>
    <p class="col-md-8 fs-4">
      Este é um destaque no topo da página, parecido com o antigo Jumbotron.
    </p>
    <button class="btn btn-primary btn-lg" type="button">Crie uma conta</button>
  </div>
</div>

<hr>

<h3>Postagens recentes: </h3>

{{#each postagem}}
    <div class="card mt-1">
        <div class="card-body">
            <h5>{{titulo}}</h5>
            <p>descrição: {{descricao}}</p>
            <p>conteúdo: {{conteudo}}</p>
            <small>{{data}}</small>
        </div>
    </div>

{{else}}
    <h5>Nenhuma postagem</h5>
{{/each}}