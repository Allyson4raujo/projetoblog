{{#each erros}}
    <div class="alert alert-danger">
        {{texto}}
    </div>
{{/each}}

<h3>Excluir categoria:</h3>
<div class="alert alert-warning">
    <strong>Atenção!</strong> Você tem certeza que deseja excluir esta categoria?
</div>

<form action="/admin/categorias/delete" method="post">
    <div class="mb-3">
        <label for="nome" class="form-label">Nome: </label>
        <input type="text" id="nome" name="nome" class="form-control" value="{{categoria.nome}}" disabled>

        <label for="slug" class="form-label">Slug:</label>
        <input type="text" name="slug" id="slug" class="form-control" value="{{categoria.slug}}" disabled>

        <input type="hidden" name="id" value="{{categoria._id}}">
        <br>

        <button type="submit" class="btn btn-danger">Confirmar Exclusão</button>
        <a href="/admin/categorias" class="btn btn-secondary">Cancelar</a>
    </div>
</form>