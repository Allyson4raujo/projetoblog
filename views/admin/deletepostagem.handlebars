{{#each erros}}
    <div class="alert alert-danger">
        {{texto}}
    </div>
{{/each}}

<h3>Excluir postagens:</h3>
<div class="alert alert-warning">
    <strong>Atenção!</strong> Você tem certeza que deseja excluir esta postagem?
</div>

<form action="/admin/postagens/delete" method="post">
    <div class="mb-3">
        <label for="titulo" class="form-label">Titulo:</label>
        <input type="text" name="titulo" id="titulo" class="form-control" value="{{titulo}}" disabled>

        <label for="descricao" class="form-label">Descrição:</label>
        <input type="text" name="descricao" id="descricao" class="form-control" value="{{descricao}}" disabled>

        <label for="conteudo" class="form-label">Conteúdo:</label>
        <textarea name="conteudo" id="conteudo" class="form-control" disabled>{{conteudo}}</textarea>

        <label for="categoria" class="form-label">Categoria:</label>
        <input type="text" class="form-control" value="{{categoria.nome}}" disabled>

        <input type="hidden" name="id" value="{{_id}}">
        <br>

        <button type="submit" class="btn btn-danger">Confirmar Exclusão</button>
        <a href="/admin/postagens" class="btn btn-secondary">Cancelar</a>
    </div>
</form>