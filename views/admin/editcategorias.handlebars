{{#each erros}}
    <div class="alert alert-danger">
        {{texto}}
    </div>
    {{else}}


{{/each}}

<h3>Editar categoria:</h3>
<form action="/admin/categorias/edit" method="post">
    <div class="mb-3">
        <label for="nome" class="form-label">Nome: </label>
        <input type="text" id="nome" name="nome" class="form-control" value="{{categoria.nome}}">

        <label for="slug" class="form-label">slug:</label>
        <input type="text" name="slug" id="slug" class="form-control" value="{{categoria.slug}}">

        <input type="hidden" name="id" id="id" value="{{categoria._id}}">
        <br>

        <button type="submit" class="btn btn-primary">Editar categoria</button>
    </div>
</form>