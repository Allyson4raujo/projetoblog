<h3>Postagens da categoria: {{categoria.nome}}</h3>

{{#each postagens}}
    <div class="card mt-1">
        <div class="card-body">
            <h5>{{titulo}}</h5>
            <p>Slug: {{slug}}</p>
            <p>Descrição: {{descricao}}</p>
            <p>Conteúdo: {{conteudo}}</p>
            <small>{{data}}</small><br>
            <a href="/postagem/{{slug}}"><button type="button" class="btn btn-primary">Ler postagem</button></a>
        </div>
    </div>
{{else}}
    <h5>Nenhuma postagem nesta categoria</h5>
{{/each}}